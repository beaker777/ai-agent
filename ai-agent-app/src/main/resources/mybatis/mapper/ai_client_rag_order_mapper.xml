<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.beaker.infrastructure.dao.IAiClientRagOrderDao">

    <resultMap id="BaseResultMap" type="com.beaker.infrastructure.dao.po.AiClientRagOrder">
        <id column="id" property="id"/>
        <result column="rag_id" property="ragId"/>
        <result column="rag_name" property="ragName"/>
        <result column="knowledge_tag" property="knowledgeTag"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="BaseColumns">
        id, rag_id, rag_name, knowledge_tag, status, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.beaker.infrastructure.dao.po.AiClientRagOrder" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_client_rag_order (rag_id, rag_name, knowledge_tag, status, create_time, update_time)
        VALUES (#{ragId}, #{ragName}, #{knowledgeTag}, #{status}, #{createTime}, #{updateTime})
    </insert>

    <update id="update" parameterType="com.beaker.infrastructure.dao.po.AiClientRagOrder">
        UPDATE ai_client_rag_order
        SET rag_id = #{ragId},
            rag_name = #{ragName},
            knowledge_tag = #{knowledgeTag},
            status = #{status},
            create_time = #{createTime},
            update_time = #{updateTime}
        WHERE id = #{id}
    </update>

    <select id="queryById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM ai_client_rag_order
        WHERE id = #{id}
    </select>

    <select id="queryAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM ai_client_rag_order
        ORDER BY id DESC
    </select>

</mapper>
