<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.beaker.infrastructure.dao.IAiAgentDao">

    <resultMap id="BaseResultMap" type="com.beaker.infrastructure.dao.po.AiAgent">
        <id column="id" property="id"/>
        <result column="agent_id" property="agentId"/>
        <result column="agent_name" property="agentName"/>
        <result column="description" property="description"/>
        <result column="channel" property="channel"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="BaseColumns">
        id, agent_id, agent_name, description, channel, status, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.beaker.infrastructure.dao.po.AiAgent" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_agent (agent_id, agent_name, description, channel, status, create_time, update_time)
        VALUES (#{agentId}, #{agentName}, #{description}, #{channel}, #{status}, #{createTime}, #{updateTime})
    </insert>

    <update id="update" parameterType="com.beaker.infrastructure.dao.po.AiAgent">
        UPDATE ai_agent
        SET agent_id = #{agentId},
            agent_name = #{agentName},
            description = #{description},
            channel = #{channel},
            status = #{status},
            create_time = #{createTime},
            update_time = #{updateTime}
        WHERE id = #{id}
    </update>

    <select id="queryById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM ai_agent
        WHERE id = #{id}
    </select>

    <select id="queryAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM ai_agent
        ORDER BY id DESC
    </select>

</mapper>
