<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.beaker.infrastructure.dao.IAiClientModelDao">

    <resultMap id="BaseResultMap" type="com.beaker.infrastructure.dao.po.AiClientModel">
        <id column="id" property="id"/>
        <result column="model_id" property="modelId"/>
        <result column="api_id" property="apiId"/>
        <result column="model_name" property="modelName"/>
        <result column="model_type" property="modelType"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="BaseColumns">
        id, model_id, api_id, model_name, model_type, status, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.beaker.infrastructure.dao.po.AiClientModel" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_client_model (model_id, api_id, model_name, model_type, status, create_time, update_time)
        VALUES (#{modelId}, #{apiId}, #{modelName}, #{modelType}, #{status}, #{createTime}, #{updateTime})
    </insert>

    <update id="update" parameterType="com.beaker.infrastructure.dao.po.AiClientModel">
        UPDATE ai_client_model
        SET model_id = #{modelId},
            api_id = #{apiId},
            model_name = #{modelName},
            model_type = #{modelType},
            status = #{status},
            create_time = #{createTime},
            update_time = #{updateTime}
        WHERE id = #{id}
    </update>

    <select id="queryById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM ai_client_model
        WHERE id = #{id}
    </select>

    <select id="queryAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM ai_client_model
        ORDER BY id DESC
    </select>

</mapper>
