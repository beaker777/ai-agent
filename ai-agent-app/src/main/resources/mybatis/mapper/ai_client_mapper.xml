<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.beaker.infrastructure.dao.IAiClientDao">

    <resultMap id="BaseResultMap" type="com.beaker.infrastructure.dao.po.AiClient">
        <id column="id" property="id"/>
        <result column="client_id" property="clientId"/>
        <result column="client_name" property="clientName"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="BaseColumns">
        id, client_id, client_name, description, status, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.beaker.infrastructure.dao.po.AiClient" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_client (client_id, client_name, description, status, create_time, update_time)
        VALUES (#{clientId}, #{clientName}, #{description}, #{status}, #{createTime}, #{updateTime})
    </insert>

    <update id="update" parameterType="com.beaker.infrastructure.dao.po.AiClient">
        UPDATE ai_client
        SET client_id = #{clientId},
            client_name = #{clientName},
            description = #{description},
            status = #{status},
            create_time = #{createTime},
            update_time = #{updateTime}
        WHERE id = #{id}
    </update>

    <select id="queryById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM ai_client
        WHERE id = #{id}
    </select>

    <select id="queryAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM ai_client
        ORDER BY id DESC
    </select>

</mapper>
